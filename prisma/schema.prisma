generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SALE
}

enum Level {
  light
  moderate
  deep
}

enum BookingStatus {
  PENDING
  PAID
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id  @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  role         Role
  active       Boolean  @default(true)
  passwordHash String?
  createdAt    DateTime @default(now())

  bookings Booking[]
}

model Location {
  id             String   @id  @default(cuid())
  nameVi         String
  nameEn         String
  type           String
  region         String
  tags           String[]
  image          String
  descriptionVi  String?
  descriptionEn  String?
  introductionVi String?
  introductionEn String?
  historyVi      String?
  historyEn      String?
  significanceVi String?
  significanceEn String?

  tours TourLocation[]
}

model Tour {
  id             String   @id  @default(cuid())
  titleVi        String
  titleEn        String
  descriptionVi  String
  descriptionEn  String
  introductionVi String
  introductionEn String
  meaningVi      String
  meaningEn      String
  priceVnd       Int
  durationDays   Float
  level          Level
  suitableForVi  String
  suitableForEn  String
  images         String[]

  locations TourLocation[]
  schedules Schedule[]
  reviews   Review[]
  bookings  Booking[]
}

model TourLocation {
  tourId     String
  locationId String

  tour     Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([tourId, locationId])
}

model Schedule {
  id        String   @id  @default(cuid())
  tourId    String
  startDate DateTime
  slots     Int
  slotsLeft Int

  tour     Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Course {
  id            String @id  @default(cuid())
  titleVi       String
  titleEn       String
  descriptionVi String
  descriptionEn String
  priceVnd      Int
  duration      String
  groupLink     String
  image         String
}

model Discount {
  code       String   @id
  percent    Int
  validUntil DateTime
  usageLimit Int
  usedCount  Int @default(0)
}

model Review {
  id        String   @id  @default(cuid())
  tourId    String
  bookingId String?  @unique
  user      String
  rating    Int
  comment   String
  date      DateTime

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)
}

model Booking {
  id           String        @id  @default(cuid())
  userId       String?       // <-- nullable
  tourId       String
  scheduleId   String
  guests       Int
  totalPrice   Int
  currency     String
  status       BookingStatus
  date         DateTime
  discountCode String?

  contactName  String?
  contactEmail String?
  contactPhone String?

  user     User?     @relation(fields: [userId], references: [id])
  tour     Tour      @relation(fields: [tourId], references: [id])
  schedule Schedule  @relation(fields: [scheduleId], references: [id])

  @@index([contactEmail])
  @@index([contactPhone])
}
